# Private content repository write access
# GITHUB_OWNER=Arsvine-Realm-Dev-Team
# GITHUB_REPO=arsvine-content
# GITHUB_BRANCH=main
# GITHUB_WRITE_TOKEN=github_pat_xxx

# Signed admin session and CSRF state
# SESSION_SECRET=replace-with-a-random-long-string

# Admin password hash generated by `npm run hash-password -- "your-password"`
# Keep `\$` as-is in `.env.local`, otherwise Next will expand `$...`.
# ADMIN_PASSWORD_HASH=scrypt\$base64url-salt\$base64url-hash

# Dedicated admin TOTP config for password+2FA login. TOTP is required by
# default in every environment; the only way to disable it is to set
# ADMIN_TOTP_DEV_BYPASS=1 *and* run with NODE_ENV != production (local dev).
# ADMIN_TOTP_JSON={"current":"JBSWY3DPEHPK3PXP","period":30,"digits":6,"window":1}
# Optional escape hatch for local development; ignored in production.
# ADMIN_TOTP_DEV_BYPASS=0

# Trust the X-Forwarded-For header for client identification (rate limiting,
# logging). Only enable when the app sits behind a reverse proxy that strips
# / overwrites the header — Vercel does this automatically. When unset, the
# rate limiter falls back to the runtime-provided socket IP, which cannot be
# spoofed by callers.
# TRUST_PROXY=0

# Persistent rate limiting for Vercel/serverless. Strongly recommended in production.
# When unset, the app falls back to a process-local Map, which is not reliable across instances.
# UPSTASH_REDIS_REST_URL=https://example.upstash.io
# UPSTASH_REDIS_REST_TOKEN=upstash-rest-token

# Public site revalidate endpoints
# Public blog revalidate endpoint (POST, body { secret, slug? })
# PUBLIC_REVALIDATE_URL=https://www.example.com/api/revalidate-content
# Public tweets revalidate endpoint (GET, ?secret=...)
# PUBLIC_TWEETS_REVALIDATE_URL=https://www.example.com/api/revalidate
# Shared secret; must match what the public site expects.
# PUBLIC_REVALIDATE_SECRET=replace-with-the-public-site-secret

# Tweet / blog auto-translation API (OpenAI-compatible; required for auto-translate / retranslate)
# AI_TRANSLATION_BASE_URL=https://api.deepseek.com/v1/
# AI_TRANSLATION_API_KEY=sk-xxxx
# AI_TRANSLATION_MODEL=deepseek-chat
# AI_TRANSLATION_THINKING=enabled
# AI_TRANSLATION_REASONING_EFFORT=high
